+    set(fmt_src ${fmt_SOURCE_DIR}/src/format.cc ${fmt_SOURCE_DIR}/src/os.cc)
+    nanobind_add_module(_jormungandr ${jormungandr_src} ${fmt_src} ${Sleipnir_src})
